# .env.example

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/dojotrack

# JWT SECRET — ganti dengan random string panjang, contoh generate:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-random-string-panjang
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# APP
APP_NAME=DojoTrack
APP_VERSION=1.0.0
DEBUG=True